# Copy this file to .env and replace the placeholders with values from Supabase (Project Settings → API).
# Restart the Vite dev server after changing .env.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Leave empty for local dev (uses Vite proxy to :4000). Set to your API origin in production.
VITE_API_URL=
